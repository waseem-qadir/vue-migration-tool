{
  "name": "vue-migration-tool",
  "version": "1.0.0",
  "description": "CLI tool for migrating Vue 2 codebases to Vue 3 using AST-based rules with LLM fallback",
  "main": "src/index.js",
  "bin": {
    "vue-migrate": "./src/cli/index.js"
  },
  "type": "module",
  "scripts": {
    "start": "node src/cli/index.js",
    "test": "node src/cli/index.js --dir ./sample-vue2-project --dry-run",
    "demo": "node src/cli/index.js --dir ./sample-vue2-project --dry-run",
    "migrate": "node src/cli/index.js --dir ./sample-vue2-project --output ./migrated-output"
  },
  "keywords": [
    "vue",
    "migration",
    "vue2",
    "vue3",
    "codemod",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@babel/generator": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "diff": "^5.2.0",
    "dotenv": "^17.4.2",
    "glob": "^10.3.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "vue-eslint-parser": "^9.4.0",
    "vue-template-compiler": "^2.7.0"
  }
}
